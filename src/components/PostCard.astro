---
interface Props {
  title: string;
  date: Date;
  summary: string;
  slug: string;
  featured?: boolean;
}

const { title, date, summary, slug, featured } = Astro.props;
---

<article class="group">
  <a href={`/writing/${slug}/`} class="block">
    <div class="flex items-start justify-between gap-4">
      <div>
        <time class="text-sm text-gray-400" datetime={date.toISOString()}>
          {
            date.toLocaleDateString("en-US", {
              year: "numeric",
              month: "short",
              day: "numeric",
            })
          }
        </time>
        <h3
          class="text-lg font-medium mt-1 group-hover:text-gray-600 transition-colors"
        >
          {title}
          {featured && <span class="ml-2 text-xs text-gray-400">Featured</span>}
        </h3>
        <p class="text-gray-500 text-sm mt-1 line-clamp-2">{summary}</p>
      </div>
      <svg
        class="w-5 h-5 text-gray-300 group-hover:text-gray-500 transition-colors flex-shrink-0 mt-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          d="M9 5l7 7-7 7"></path>
      </svg>
    </div>
  </a>
</article>
