---
interface Props {
  name: string;
  type: string;
  stack: string[];
  repo: string;
  highlights: string[];
}

const { name, type, stack, repo, highlights } = Astro.props;
---

<article class="border border-gray-100 rounded-lg p-6 hover:border-gray-200 transition-colors">
  <div class="flex items-start justify-between gap-4">
    <div>
      <span class="text-xs text-gray-400 uppercase tracking-wide">{type}</span>
      <h3 class="text-lg font-medium mt-1">{name}</h3>
    </div>
    <div class="flex gap-1">
      {stack.map((tech) => (
        <span class="px-2 py-0.5 bg-gray-100 text-gray-600 text-xs rounded">{tech}</span>
      ))}
    </div>
  </div>
  
  <ul class="mt-4 space-y-1">
    {highlights.map((highlight) => (
      <li class="text-sm text-gray-600 flex items-start gap-2">
        <span class="text-gray-300 mt-1">•</span>
        <span>{highlight}</span>
      </li>
    ))}
  </ul>
  
  <a
    href={repo}
    target="_blank"
    rel="noopener"
    class="inline-flex items-center gap-1 mt-4 text-sm text-gray-500 hover:text-gray-900 transition-colors"
  >
    View on GitHub
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
    </svg>
  </a>
</article>
