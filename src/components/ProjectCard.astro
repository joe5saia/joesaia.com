---
interface Props {
  name: string;
  type: string;
  stack: string[];
  repo: string;
  highlights: string[];
}

const { name, type, stack, repo, highlights } = Astro.props;
---

<article
  class="border border-border rounded-lg p-6 hover:border-border-hover transition-colors"
>
  <div class="flex items-start justify-between gap-4">
    <div>
      <span class="text-xs text-accent uppercase tracking-wide">{type}</span>
      <h3 class="text-lg font-medium mt-1 text-text-heading">{name}</h3>
    </div>
    <div class="flex gap-1">
      {
        stack.map((tech) => (
          <span class="px-2 py-0.5 bg-accent-subtle text-accent text-xs rounded">
            {tech}
          </span>
        ))
      }
    </div>
  </div>

  <ul class="mt-4 space-y-1">
    {
      highlights.map((highlight) => (
        <li class="text-sm text-text-secondary flex items-start gap-2">
          <span class="text-text-muted mt-1">•</span>
          <span>{highlight}</span>
        </li>
      ))
    }
  </ul>

  <a
    href={repo}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={`View ${name} on GitHub`}
    class="inline-flex items-center gap-1 mt-4 text-sm text-accent hover:text-accent-hover transition-colors"
  >
    View on GitHub
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="1.5"
        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
      ></path>
    </svg>
  </a>
</article>
