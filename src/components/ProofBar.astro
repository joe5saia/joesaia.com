---
interface Metric {
  value: string;
  label: string;
}

interface Props {
  metrics: Metric[];
}

const { metrics } = Astro.props;
---

<div class="grid grid-cols-1 gap-6 py-6 border-y border-gray-100">
  {
    metrics.map((metric) => (
      <div class="text-center">
        <div class="text-2xl font-semibold text-gray-900">{metric.value}</div>
        <div class="text-sm text-gray-500 mt-1">{metric.label}</div>
      </div>
    ))
  }
</div>
