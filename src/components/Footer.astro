---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border mt-auto">
  <div class="max-w-3xl mx-auto px-6 py-8">
    <div
      class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-text-secondary"
    >
      <p>&copy; {currentYear} Joe Saia. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <a
          href="https://github.com/joe5saia/"
          class="hover:text-text-heading transition-colors"
          target="_blank"
          rel="noopener"
        >
          GitHub
        </a>
        <a
          href="https://www.linkedin.com/in/joe-saia/"
          class="hover:text-text-heading transition-colors"
          target="_blank"
          rel="noopener"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</footer>
