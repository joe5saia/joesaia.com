---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'writing'>;
}

const { post } = Astro.props;
const { title, date, summary, tags } = post.data;
---

<BaseLayout title={title} description={summary} type="article">
  <article class="prose prose-gray max-w-none">
    <header class="mb-8 not-prose">
      <time class="text-sm text-gray-500" datetime={date.toISOString()}>
        {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <h1 class="text-3xl font-bold mt-2 mb-4">{title}</h1>
      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {tags.map((tag: string) => (
            <span class="px-2 py-1 bg-gray-100 text-gray-600 text-xs rounded">{tag}</span>
          ))}
        </div>
      )}
    </header>
    <slot />
  </article>
</BaseLayout>
