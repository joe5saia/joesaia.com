---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page Not Found — Joe Saia"
  description="The page you're looking for doesn't exist."
  noindex={true}
>
  <div class="text-center py-16">
    <p class="text-6xl font-bold text-text-muted mb-4">404</p>
    <h1 class="text-2xl font-bold mb-2 text-text-heading">Page Not Found</h1>
    <p class="text-text-secondary mb-8">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a
      href="/"
      class="inline-flex items-center px-4 py-2 bg-btn-bg text-text-heading text-sm font-medium rounded hover:bg-btn-bg-hover transition-colors"
    >
      Go Home
    </a>
  </div>
</BaseLayout>
