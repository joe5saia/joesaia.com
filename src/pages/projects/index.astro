---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
---

<BaseLayout title="Projects — Joe Saia">
    <h1 class="text-3xl font-bold mb-4">Projects</h1>
    <p class="text-gray-600 mb-12">
        Open-source packages I've built for statistical computing, causal
        inference, and macroeconomic analysis
    </p>

    {
        projects.length > 0 ? (
            <div class="grid gap-6">
                {projects.map((project) => (
                    <ProjectCard
                        name={project.data.name}
                        type={project.data.type}
                        stack={project.data.stack}
                        repo={project.data.repo}
                        highlights={project.data.highlights}
                    />
                ))}
            </div>
        ) : (
            <p class="text-gray-500">No projects yet. Check back soon.</p>
        )
    }
</BaseLayout>
