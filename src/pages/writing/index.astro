---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("writing")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout
  title="Writing — Joe Saia"
  description="Articles on data engineering, analytics leadership, and AI-augmented development."
>
  <h1 class="text-3xl font-bold mb-4">Writing</h1>

  {
    posts.length > 0 ? (
      <div class="grid gap-6">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            date={post.data.date}
            summary={post.data.summary}
            slug={post.slug}
            featured={post.data.featured}
          />
        ))}
      </div>
    ) : (
      <p class="text-gray-500">No posts yet. Check back soon.</p>
    )
  }
</BaseLayout>
