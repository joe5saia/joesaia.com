---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Resume — Joe Saia">
  <h1 class="text-3xl font-bold mb-4">Resume</h1>
  <p class="text-gray-600 mb-8">
    Over a decade of building data platforms, shipping production systems, and
    leading lean engineering teams that use AI and automation to move fast with
    fewer people.
  </p>

  <div class="border border-gray-200 rounded-lg p-8 text-center">
    <div class="mb-6">
      <svg
        class="w-16 h-16 mx-auto text-gray-300"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1"
          d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
        ></path>
      </svg>
    </div>
    <h2 class="text-lg font-medium mb-2">Resume.pdf</h2>
    <p class="text-sm text-gray-500 mb-6">Updated December 2025</p>
    <a
      href="/joe_saia_resume.pdf"
      download
      class="inline-flex items-center px-6 py-3 bg-gray-900 text-white font-medium rounded hover:bg-gray-800 transition-colors"
    >
      <svg
        class="w-5 h-5 mr-2"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
        ></path>
      </svg>
      Download Resume
    </a>
  </div>

  <section class="mt-12">
    <h2 class="text-xl font-semibold mb-6">Leadership Highlights</h2>
    <ul class="space-y-4 text-gray-600">
      <li class="flex items-start gap-3">
        <span class="text-gray-300 mt-1">•</span>
        <span
          >Transformed legacy team which used waterfall development dressed up
          as Scrum agile into a truely agile, high-agency team that was able to
          respond to customer pain points immediately</span
        >
      </li>
      <li class="flex items-start gap-3">
        <span class="text-gray-300 mt-1">•</span>
        <span
          >Drove adoption of AI coding agents and LLM-augmented workflows to
          multiply team output, and allow focus on the actual hard problems at
          hand</span
        >
      </li>
      <li class="flex items-start gap-3">
        <span class="text-gray-300 mt-1">•</span>
        <span
          >Designed scalable data platforms with data quality, observability,
          and reproducibility as first-class concerns</span
        >
      </li>
      <li class="flex items-start gap-3">
        <span class="text-gray-300 mt-1">•</span>
        <span
          >Stood up modern data stack pipelines using Fivetran, Snowflake and
          Sigma to let business leaders drive their insights without needing to
          including data analysts or engineers for every question
        </span>
      </li>
      <li class="flex items-start gap-3">
        <span class="text-gray-300 mt-1">•</span>
        <span
          >Designed and implemented measurable business operations workflows
          using Salesforce and homegrown data services to allow for
          experimentation, measurement and continous improvement
        </span>
      </li>
    </ul>
  </section>
</BaseLayout>
