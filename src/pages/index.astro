---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProofBar from "../components/ProofBar.astro";
import PostCard from "../components/PostCard.astro";
import { getCollection } from "astro:content";

const featuredPosts = (await getCollection("writing"))
    .filter((post) => post.data.featured)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .slice(0, 3);

const metrics = [{ value: "10+", label: "Years in Engineering & Analytics" }];

const beliefs = [
    {
        title: "Small Teams, Outsized Impact",
        description:
            "The best work comes from small, focused teams with full ownership and responsibility. I build teams where every person is a force multiplier not a cog.",
    },
    {
        title: "AI as a Core Competency",
        description:
            "Local AI agents and LLM-augmented workflows aren't nice-to-haves, they are what transform us into T-shaped business partners.",
    },
    {
        title: "Autonomy Over Process",
        description:
            "I hire people I trust and give them room to run. Clear goals, short feedback loops, and the freedom to choose how to get there.",
    },
    {
        title: "Constant Experimentation",
        description:
            "The global maximum is always moving, tweaking and measuring ourselves is how we stay at the frontier.",
    },
];
---

<BaseLayout title="Joe Saia — Engineering and Analytics Leader">
    <!-- Hero -->
    <section class="mb-16">
        <h1 class="text-4xl font-bold tracking-tight mb-4">
            I build small teams that punch above their weight.
        </h1>
        <p class="text-xl text-gray-600 leading-relaxed mb-4">
            Engineering and analytics leader with over a decade of experience
            building data platforms, shipping production systems, and leading
            highly autonomous teams that use AI to build leverage in order to
            move faster and efficiently.
        </p>
        <p class="text-lg text-gray-500 leading-relaxed mb-8">
            I focus on hiring sharp people, giving them real ownership, and
            using modern tooling — including AI coding agents — to make org-wide
            impacts.
        </p>
        <div class="flex flex-wrap gap-4">
            <a
                href="/joe_saia_resume.pdf"
                class="inline-flex items-center px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded hover:bg-gray-800 transition-colors"
            >
                Download Resume
            </a>
            <a
                href="/contact/"
                class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded hover:border-gray-400 transition-colors"
            >
                Get in Touch
            </a>
        </div>
    </section>

    <ProofBar metrics={metrics} />

    <!-- What I Believe -->
    <section class="mt-16">
        <h2 class="text-xl font-semibold mb-8">What I Believe</h2>
        <div class="grid gap-8 sm:grid-cols-2">
            {
                beliefs.map((belief) => (
                    <div>
                        <h3 class="font-medium mb-2">{belief.title}</h3>
                        <p class="text-sm text-gray-600 leading-relaxed">
                            {belief.description}
                        </p>
                    </div>
                ))
            }
        </div>
    </section>

    <!-- Featured Writing -->
    {
        featuredPosts.length > 0 && (
            <section class="mt-16">
                <div class="flex items-center justify-between mb-8">
                    <h2 class="text-xl font-semibold">Featured Writing</h2>
                    <a
                        href="/writing/"
                        class="text-sm text-gray-500 hover:text-gray-900 transition-colors"
                    >
                        View all →
                    </a>
                </div>
                <div class="space-y-8">
                    {featuredPosts.map((post) => (
                        <PostCard
                            title={post.data.title}
                            date={post.data.date}
                            summary={post.data.summary}
                            slug={post.slug}
                            featured={post.data.featured}
                        />
                    ))}
                </div>
            </section>
        )
    }

    <!-- CTA -->
    <section class="mt-16 border-t border-gray-100 pt-12">
        <p class="text-gray-600 mb-4">
            Looking for a leader who builds lean, AI-fluent engineering teams?
        </p>
        <div class="flex flex-wrap gap-4">
            <a
                href="/contact/"
                class="inline-flex items-center px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded hover:bg-gray-800 transition-colors"
            >
                Let's Talk
            </a>
            <a
                href="/projects/"
                class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded hover:border-gray-400 transition-colors"
            >
                View Projects
            </a>
        </div>
    </section>
</BaseLayout>
