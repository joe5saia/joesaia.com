---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProofBar from "../components/ProofBar.astro";

const metrics = [{ value: "10+", label: "Years in Engineering & Analytics" }];

const beliefs = [
  {
    title: "Small Teams, Outsized Impact",
    description:
      "The best work comes from small, focused teams with full ownership and responsibility. I build teams that empower individuals to make impacts",
  },
  {
    title: "AI as a Core Competency",
    description:
      "Judicious AI use lets work in new ways that unlock new possibilities for what is possible",
  },
  {
    title: "Autonomy Over Process",
    description:
      "I hire people I trust and give them room to run. Clear goals, short feedback loops, and the freedom to choose how to get there.",
  },
  {
    title: "Constant Experimentation",
    description:
      "The global maximum is always moving, tweaking and measuring ourselves is how we stay at the frontier.",
  },
];
---

<BaseLayout title="Joe Saia — Engineering and Analytics Leader">
  <!-- Hero -->
  <section class="mb-16">
    <h1 class="text-4xl font-bold tracking-tight mb-4 text-text-heading">
      I build small teams that punch above their weight.
    </h1>
    <p class="text-xl text-text-secondary leading-relaxed mb-4">
      Engineering and analytics leader with over a decade of experience building
      data platforms, shipping production systems, and leading highly autonomous
      teams that use AI to build leverage in order to move faster and
      efficiently.
    </p>
    <p class="text-lg text-text-secondary leading-relaxed mb-8">
      I focus on hiring sharp people, giving them real ownership, and using
      modern tooling — including AI coding agents — to make org-wide impacts.
    </p>
    <div class="flex flex-wrap gap-4">
      <a
        href="/joe_saia_resume.pdf"
        class="inline-flex items-center px-4 py-2 bg-btn-bg text-text-heading text-sm font-medium rounded hover:bg-btn-bg-hover transition-colors"
      >
        Download Resume
      </a>
      <a
        href="/contact/"
        class="inline-flex items-center px-4 py-2 border border-border text-sm font-medium rounded hover:border-border-hover transition-colors"
      >
        Get in Touch
      </a>
    </div>
  </section>

  <ProofBar metrics={metrics} />

  <!-- What I Believe -->
  <section class="mt-16">
    <h2 class="text-xl font-semibold mb-8 text-text-heading">What I Believe</h2>
    <div class="grid gap-8 sm:grid-cols-2">
      {
        beliefs.map((belief) => (
          <div>
            <h3 class="font-medium mb-2 text-text-heading">{belief.title}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">
              {belief.description}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- CTA -->
  <section class="mt-16 border-t border-border pt-12">
    <p class="text-text-secondary mb-4">
      Looking for a leader who builds lean, AI-fluent engineering teams?
    </p>
    <div class="flex flex-wrap gap-4">
      <a
        href="/contact/"
        class="inline-flex items-center px-4 py-2 bg-btn-bg text-text-heading text-sm font-medium rounded hover:bg-btn-bg-hover transition-colors"
      >
        Let's Talk
      </a>
      <a
        href="/projects/"
        class="inline-flex items-center px-4 py-2 border border-border text-sm font-medium rounded hover:border-border-hover transition-colors"
      >
        View Projects
      </a>
    </div>
  </section>
</BaseLayout>
