---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProofBar from '../components/ProofBar.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const featuredPosts = (await getCollection('writing'))
  .filter((post) => post.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const metrics = [
  { value: '10+', label: 'Years Experience' },
  { value: '50+', label: 'Data Pipelines' },
  { value: '5', label: 'Open Source Projects' },
];
---

<BaseLayout title="Joe Saia — Engineering and Analytics Leader">
  <section class="mb-16">
    <h1 class="text-4xl font-bold tracking-tight mb-4">
      Engineering and Analytics Leader
    </h1>
    <p class="text-xl text-gray-600 leading-relaxed mb-8">
      I've been writting code 
    </p>
    <div class="flex flex-wrap gap-4">
      <a
        href="/joe_saia_resume.pdf"
        class="inline-flex items-center px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded hover:bg-gray-800 transition-colors"
      >
        Download Resume
      </a>
      <a
        href="/contact/"
        class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded hover:border-gray-400 transition-colors"
      >
        Get in Touch
      </a>
    </div>
  </section>

  <ProofBar metrics={metrics} />

  {featuredPosts.length > 0 && (
    <section class="mt-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-xl font-semibold">Featured Writing</h2>
        <a href="/writing/" class="text-sm text-gray-500 hover:text-gray-900">View all →</a>
      </div>
      <div class="space-y-8">
        {featuredPosts.map((post) => (
          <PostCard
            title={post.data.title}
            date={post.data.date}
            summary={post.data.summary}
            slug={post.slug}
            featured={post.data.featured}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
